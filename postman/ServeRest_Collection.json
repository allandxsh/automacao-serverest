    {
      "name": "Performance",
      "item": [
        {
          "name": "Teste de Performance",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let iteracaoAtual = pm.info.iteration; \r",
                  "\r",
                  "if (iteracaoAtual < 100) {\r",
                  "    pm.test(`Requisição ${iteracaoAtual + 1}: Status 200 (Sucesso)`, function () {\r",
                  "        pm.response.to.have.status(200);\r",
                  "    });\r",
                  "} else {\r",
                  "    pm.test(`- Req 101: Deveria ser 429 (Rate Limit), mas API retornou ${pm.response.code}`, function () {\r",
                  "        pm.expect(pm.response.code).to.be.oneOf([200, 429]);\r",
                  "    });\r",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
